# .env.example — copy this to .env and fill in your values.
# Never commit .env to version control (it is in .gitignore).

# Your Notion Internal Integration Token.
# Create one at https://www.notion.so/my-integrations
# It starts with "secret_"
NOTION_TOKEN=secret_your_token_here

# The ID of the Notion page under which "Job Search HQ" will be created.
# Get it from the page URL: notion.so/{workspace}/{PAGE_ID}?v=...
# It looks like: 1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d
NOTION_PARENT_PAGE_ID=your_parent_page_id_here
